# Min 32 chars — e.g. openssl rand -base64 32
NUXT_SESSION_PASSWORD=

# Session cookie Secure flag. Dev defaults to false (required for iOS Safari on LAN HTTP).
# Production should use HTTPS with secure cookies (default true when NODE_ENV=production).
# NUXT_SESSION_COOKIE_SECURE=false

# SMTP (future OTP delivery)
# NUXT_SMTP_HOST=
# NUXT_SMTP_PORT=587
# NUXT_SMTP_USER=
# NUXT_SMTP_PASS=
# NUXT_SMTP_FROM=noreply@example.com
