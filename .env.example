# Min 32 chars — e.g. openssl rand -base64 32
NUXT_SESSION_PASSWORD=

# Server-only — minisite BFF proxy target (never expose to client).
# Production default matches nuxt.config: https://minisite-roan.vercel.app
NUXT_MINISITE_API_BASE=https://minisite-roan.vercel.app

# Optional — only when deployed minisite sets PUBLIC_API_KEY on /api/public/* (X-API-Key).
# NUXT_MINISITE_PUBLIC_API_KEY=

# --- Local minisite (optional) ---
# Point at your running minisite origin (no trailing /api).
# NUXT_MINISITE_API_BASE=http://localhost:3001
# Restart `npm run dev` after changing.

# --- Azure AD SAML SSO (Service Provider) ---
# Register these SP values in Azure AD Enterprise Application (SAML):
#   Reply URL / ACS:     https://amplifaiweek.loreal.sg/api/auth/saml/acs
#   Identifier / Entity: https://amplifaiweek.loreal.sg
#   Sign-on URL:         https://amplifaiweek.loreal.sg/api/auth/saml/login
#   SP metadata:         https://amplifaiweek.loreal.sg/api/auth/saml/metadata
NUXT_SAML_ENTITY_ID=https://amplifaiweek.loreal.sg
NUXT_SAML_ACS_URL=https://amplifaiweek.loreal.sg/api/auth/saml/acs
# From IT after Azure AD app provisioning (SAML Login URL + Base64 certificate):
NUXT_SAML_IDP_SSO_URL=
NUXT_SAML_IDP_CERT=
# Passwordless compatibility: disable strict RequestedAuthnContext by default.
# Set false only if IdP policy requires strict SP-requested auth context.
NUXT_SAML_DISABLE_REQUESTED_AUTHN_CONTEXT=true
# Force fresh credential prompt each login request (usually keep false).
NUXT_SAML_FORCE_AUTHN=false

# Local dev mock SSO (no IdP credentials needed). UI stays identical.
# Unset → mock SSO in `npm run dev` only. Set explicitly on Cloudflare Pages / Vercel per environment.
# NUXT_AUTH_BYPASS=true
# NUXT_AUTH_BYPASS=false

# --- Cloudflare Pages (Git deploy) ---
# Build: npm run build | Output: dist | NODE_VERSION=20 in dashboard
# Local Worker preview: copy .dev.vars.example → .dev.vars, then npm run pages:preview
#
# Preview (*.pages.dev) — optional SAML if testing IdP on preview URL:
#   NUXT_AUTH_BYPASS=true
#   NUXT_SAML_ENTITY_ID=https://YOUR-PROJECT.pages.dev
#   NUXT_SAML_ACS_URL=https://YOUR-PROJECT.pages.dev/api/auth/saml/acs
#
# Production (custom domain amplifaiweek.loreal.sg):
#   NUXT_AUTH_BYPASS=false
#   NUXT_SAML_ENTITY_ID=https://amplifaiweek.loreal.sg
#   NUXT_SAML_ACS_URL=https://amplifaiweek.loreal.sg/api/auth/saml/acs
# Register Production ACS URL in Azure AD (not pages.dev).

# Dev HTTPS (camera QR on phone via LAN). `npm run dev` enables HTTPS by default.
# NUXT_DEV_HTTPS=false
# NUXT_DEV_HTTPS_DOMAINS=localhost,127.0.0.1,192.168.1.10

# --- iOS Safari over Wi‑Fi (recommended) ---
# 1. On PC: choco install mkcert  (or winget install FiloSottile.mkcert)
# 2. mkcert -install
# 3. mkdir .cert  (or let `npm run dev` auto-generate if mkcert is installed)
#    mkcert -key-file .cert/localhost-key.pem -cert-file .cert/localhost.pem localhost 127.0.0.1 ::1 YOUR_LAN_IP
# 4. Email/AirDrop %LOCALAPPDATA%\mkcert\rootCA.pem to iPhone → install profile
# 5. iPhone: Settings → General → About → Certificate Trust Settings → enable mkcert
# 6. npm run dev → open https://YOUR_LAN_IP:3000 (terminal prints Network URL)
# Without mkcert: dev script sets NODE_TLS_REJECT_UNAUTHORIZED=0 for local SSR/IPX only.
# Safari may still warn; tap Advanced → visit (camera may fail until mkcert is on phone).
# NUXT_DEV_HTTPS_KEY=.cert/localhost-key.pem
# NUXT_DEV_HTTPS_CERT=.cert/localhost.pem

# Session cookie Secure flag. Auto true when dev HTTPS is on or in production.
# NUXT_SESSION_COOKIE_SECURE=false
